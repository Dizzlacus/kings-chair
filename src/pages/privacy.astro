---
import BaseLayout from "../layouts/BaseLayout.astro";

const updated = new Date().toLocaleDateString("en-AU", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<BaseLayout
  title="Privacy Policy — King's Chair"
  description="Privacy policy for the King's Chair website."
  bodyClass="legal-page"
>
  <nav class="border-b border-white/10 bg-black/95 backdrop-blur-sm">
    <div class="site-container h-16 flex items-center">
      <a href={base} class="text-sm font-semibold tracking-wider text-white hover:text-salon-orange transition-colors"
        >← King's Chair</a
      >
    </div>
  </nav>
  <main class="site-container py-12 md:py-16">
    <div class="max-w-3xl">
      <h1 class="font-display text-3xl md:text-4xl font-semibold mb-6">Privacy Policy</h1>
      <p class="text-white/65 leading-relaxed mb-4">
        This is a placeholder privacy policy for the King's Chair website. Replace this text with your own policy describing how you
        collect, use, and protect personal information (including contact details and analytics, if applicable).
      </p>
      <p class="text-white/65 leading-relaxed mb-4">Last updated: {updated}</p>
    </div>
  </main>
  <footer class="border-t border-white/10 py-8 text-center text-sm text-white/60">
    <a href={base} class="hover:text-salon-orange transition-colors">Back to home</a>
  </footer>
</BaseLayout>
