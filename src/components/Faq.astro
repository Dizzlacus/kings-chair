---
import { faqs } from "../data/faq";

const useTwoColumns = faqs.length > 6;
const mid = Math.ceil(faqs.length / 2);
const columns = useTwoColumns ? [faqs.slice(0, mid), faqs.slice(mid)] : [faqs];
---

<section id="faq" class="bg-salon-grey w-full max-w-full overflow-hidden pb-[var(--section-space)]">
  <div class="site-container w-full">
    <div class="reveal text-center mb-10 md:mb-14">
      <p class="text-[0.65rem] font-medium tracking-[0.25em] uppercase text-white/50 mb-3">05 / FAQ</p>
      <h2 class="font-display text-4xl md:text-6xl font-semibold text-white mb-4">
        Frequently Asked Questions
      </h2>
      <p class="text-white/65 max-w-md mx-auto leading-relaxed text-sm md:text-base">
        Answers to common questions about appointments, colour, and consultations at King's Chair.
      </p>
    </div>

    <div
      class:list={[
        "faq-list mx-auto",
        useTwoColumns ? "faq-list--columns max-w-5xl" : "max-w-3xl",
      ]}
    >
      {
        columns.map((column) => (
          <div class="faq-column">
            {column.map((item) => (
              <details class="faq-item border-b border-white/10">
                <summary class="faq-summary flex items-center justify-between gap-4 py-5 cursor-pointer list-none text-left text-white text-sm md:text-base font-medium leading-snug hover:text-salon-orange transition-colors">
                  <span>{item.question}</span>
                  <svg
                    class="faq-chevron w-4 h-4 shrink-0 text-white/50"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="faq-answer pb-5 pr-8 text-white/65 text-sm md:text-base leading-relaxed">
                  <p>{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>
