---
import { reviews } from "../data/reviews";
---

<section id="reviews" class="bg-salon-grey w-full max-w-full overflow-hidden pb-[var(--section-space)]">
  <div class="site-container">
    <div class="reveal section-heading flex flex-col gap-4 md:flex-row md:items-end md:justify-between md:gap-6">
      <div>
        <p class="text-[0.65rem] font-medium tracking-[0.25em] uppercase text-white/50 mb-3">03 / Reviews</p>
        <h2 class="font-display text-4xl md:text-6xl font-semibold text-white leading-tight md:max-w-[600px]">
          An Experience Worth Sharing
        </h2>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <button
          id="reviews-prev"
          type="button"
          class="w-10 h-10 flex items-center justify-center text-white/80 hover:text-salon-orange transition-colors cursor-pointer"
          aria-label="Previous review"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <button
          id="reviews-next"
          type="button"
          class="w-10 h-10 flex items-center justify-center text-white/80 hover:text-salon-orange transition-colors cursor-pointer"
          aria-label="Next review"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>

    <div class="relative site-bleed-right reveal">
      <div id="reviews-track" class="flex gap-4 md:gap-5 overflow-x-auto snap-x snap-mandatory pb-2">
        {
          reviews.map((review) => (
            <article class="review-card shrink-0 w-[85vw] sm:w-[55vw] md:w-[42vw] lg:w-[36vw] max-w-[520px] pl-5 md:pl-6 py-2 grid grid-cols-[auto_1fr] gap-x-4 md:gap-x-5">
              <span class="review-quote self-start" aria-hidden="true">
                “
              </span>
              <blockquote class="text-white/80 text-lg md:text-xl leading-relaxed self-start">
                <p>{review.quote}</p>
              </blockquote>
              <footer class="col-start-2 pt-5">
                <p class="font-medium text-white text-xs tracking-[0.15em] uppercase">{review.name}</p>
                <p class="text-white/50 text-xs tracking-wide mt-1">{review.location}</p>
              </footer>
            </article>
          ))
        }
        <div class="site-scroll-end" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>
