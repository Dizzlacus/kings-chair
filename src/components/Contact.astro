---
import { business, allanInstagram, livInstagram } from "../data/business";
---

<section id="contact" class="bg-salon-grey w-full max-w-full overflow-hidden pb-[var(--section-space)]">
  <div class="site-container text-center w-full">
    <div class="reveal">
      <p class="text-[0.65rem] font-medium tracking-[0.25em] uppercase text-white/50 mb-3">04 / Visit</p>
      <h2 class="font-display text-4xl md:text-6xl font-semibold text-white mb-4">Visit us</h2>
      <p class="text-white/65 max-w-md mx-auto mb-10 leading-relaxed text-sm md:text-base">
        Find us at Hivetree in Newcastle city centre. Book via Instagram or get in touch below.
      </p>
      <address class="not-italic space-y-2 text-white/80 mb-8">
        <p>
          <a
            href={business.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-salon-orange transition-colors"
          >
            {business.address.streetAddress}<br />
            {business.address.addressLocality} {business.address.postalCode}
          </a>
        </p>
      </address>
      <div class="hero-cta-group mx-auto">
        <a
          href={allanInstagram.url}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-cta inline-flex items-center justify-center gap-2 px-5 sm:px-6 py-3 text-[0.65rem] sm:text-xs font-medium tracking-[0.15em] sm:tracking-[0.2em] uppercase text-white transition-colors"
        >
          {allanInstagram.handle}
          <span aria-hidden="true">↗</span>
        </a>
        <a
          href={livInstagram.url}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-cta inline-flex items-center justify-center gap-2 px-5 sm:px-6 py-3 text-[0.65rem] sm:text-xs font-medium tracking-[0.15em] sm:tracking-[0.2em] uppercase text-white transition-colors"
        >
          {livInstagram.handle}
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </div>
</section>
