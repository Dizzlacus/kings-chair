---
import { Image } from "astro:assets";
import aboutTeam from "../assets/images/gallery/about-team.png";
---

<section id="about" class="bg-salon-grey w-full max-w-full overflow-hidden pb-[var(--section-space)]">
  <div class="site-container w-full">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center w-full min-w-0">
      <div class="reveal">
        <p class="text-[0.65rem] font-medium tracking-[0.25em] uppercase text-white/50 mb-3">02 / About</p>
        <h2 class="font-display text-4xl md:text-6xl font-semibold text-white mb-6">About the salon</h2>
        <p class="text-white/65 leading-relaxed mb-4 text-sm md:text-base">
          King's Chair at Hivetree brings together bespoke, creative and technical expertise under one roof in Newcastle upon Tyne.
        </p>
        <p class="text-white/65 leading-relaxed mb-8 text-sm md:text-base">
          Whether you're after a fresh shape, a colour refresh, or something special for an occasion, our stylists take the time to listen
          and create a look you'll love.
        </p>
        <div class="space-y-6">
          <div>
            <p class="text-sm font-medium text-white mb-1">Allan Kingsland</p>
            <p class="text-white/65 text-sm leading-relaxed mb-2">Multi-award winning Wella Color Expert.</p>
            <a
              href="https://www.instagram.com/allankingslandhair/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-salon-orange hover:text-white transition-colors"
            >
              @allankingslandhair
              <span aria-hidden="true">↗</span>
            </a>
          </div>
          <div>
            <p class="text-sm font-medium text-white mb-1">Liv Griffin</p>
            <p class="text-white/65 text-sm leading-relaxed mb-2">Bespoke, creative and technical expertise.</p>
            <a
              href="https://www.instagram.com/hair_bylivgriffin/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-salon-orange hover:text-white transition-colors"
            >
              @hair_bylivgriffin
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
      <div class="reveal reveal-delay-1 site-bleed-right">
        <div class="crop-frame aspect-[4/3] w-full bg-salon-grey overflow-hidden">
          <span class="crop-mark crop-mark-tl" aria-hidden="true"></span>
          <span class="crop-mark crop-mark-tr" aria-hidden="true"></span>
          <span class="crop-mark crop-mark-bl" aria-hidden="true"></span>
          <span class="crop-mark crop-mark-br" aria-hidden="true"></span>
          <Image
            src={aboutTeam}
            alt="Liv Griffin and Allan Kingsland at King's Chair"
            class="w-full h-full object-cover object-center"
            widths={[480, 720, 960]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
