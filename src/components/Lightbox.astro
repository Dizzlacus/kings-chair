<div
  id="gallery-lightbox"
  class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Gallery image"
  aria-hidden="true"
>
  <button
    id="lightbox-close"
    type="button"
    class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center text-white/80 hover:text-white transition-colors"
    aria-label="Close"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  <figure class="relative max-w-4xl max-h-[90vh] flex flex-col items-center p-3">
    <span class="crop-mark crop-mark-tl" aria-hidden="true"></span>
    <span class="crop-mark crop-mark-tr" aria-hidden="true"></span>
    <span class="crop-mark crop-mark-bl" aria-hidden="true"></span>
    <span class="crop-mark crop-mark-br" aria-hidden="true"></span>
    <img id="lightbox-image" src="" alt="" class="max-w-full max-h-[80vh] object-contain" />
    <figcaption id="lightbox-caption" class="mt-4 text-sm text-white/65 tracking-wide"></figcaption>
  </figure>
</div>
