---
import { allanInstagram, livInstagram } from "../data/business";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<footer class="border-t border-white/10 pb-10 pt-10 text-center text-sm text-white/60 bg-salon-grey w-full max-w-full overflow-hidden">
  <div class="site-container">
    <p class="mb-3">&copy; <span id="footer-year"></span> King's Chair. All rights reserved.</p>
    <p class="mb-3">
      <a
        href={allanInstagram.url}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-salon-orange transition-colors">{allanInstagram.handle}</a
      >
      <span class="mx-2">·</span>
      <a
        href={livInstagram.url}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-salon-orange transition-colors">{livInstagram.handle}</a
      >
    </p>
    <p>
      <a href={`${base}terms`} class="hover:text-salon-orange transition-colors">Terms</a>
      <span class="mx-2">·</span>
      <a href={`${base}privacy`} class="hover:text-salon-orange transition-colors">Privacy</a>
    </p>
  </div>
</footer>
